# ─── Turso (libSQL) database ─────────────────────────────────────────────────
# Create a free database at turso.tech
# turso db create niftylens && turso db show niftylens && turso db tokens create niftylens
TURSO_DATABASE_URL=libsql://<db-name>-<org>.turso.io
TURSO_AUTH_TOKEN=<your-turso-auth-token>

# ─── Cron & Admin secrets ─────────────────────────────────────────────────────
# Protects GET /api/refresh (Vercel Cron) — must match: Authorization: Bearer <secret>
# Leave unset in local dev to disable auth check.
CRON_SECRET=

# Protects POST /api/admin/bond-yield and POST /api/admin/sip
# Falls back to CRON_SECRET if unset.
ADMIN_SECRET=

# ─── Site URL (required for OG image absolute URLs in production) ─────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ─── Footer links ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_NAME=Your Name
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username/niftylens
